%================ # 09 ========================================
\begin{frame}[fragile]{UV $\leadsto$ the new Python project/PVE manager}

  \begin{minipage}[t][][t]{1.\textwidth}
    \begin{tcolorbox}[title=Command: \boldtt{uv init [dir]}, add to width=5mm]
      \begin{itemize}
      \item Create a project directory with a PVE inside:
        \begin{minted}[fontsize=\fontsize{9}{9}\selectfont, bgcolor=VeryLightYellow]{bash}
uv init myproj
        \end{minted}
      \item Initialize a PVE within an existing directory:
        \begin{minted}[fontsize=\fontsize{9}{9}\selectfont, bgcolor=VeryLightYellow]{bash}
cd myproj
uv init
        \end{minted}
      \end{itemize}
    \end{tcolorbox}
    
    \visible<2->
        {\small Creates/uses the directory \file{myproj} and creates inside:
          \begin{itemize}\setlength\itemsep{0mm}
          \item<3-> \file{.gitignore} \& \file{README.md} files and a ready to use \file{.git} sub-dir 
          \item<4-> \file{pyproject.toml}: lists the version of the installed Python modules
          \item<5-> \file{.python-version}: the version of the PVE's interpreter
          \item<6-> \file{uv.lock}: detailed informations about modules dependencies
          \item<7-> as soon as necessary creates the \file{.venv} sub-directory to hold the PVE with the right version of the Python interpreter. 
          \end{itemize}
        }
  \end{minipage}\begin{minipage}[t][][b]{.1\textwidth}
    \only<8>{\vspace*{-45mm}\hspace*{-110mm}\includegraphics[width=10\textwidth, frame]{images/uv_init_myproj.png}}
  \end{minipage}
\end{frame}
%==============================================================

