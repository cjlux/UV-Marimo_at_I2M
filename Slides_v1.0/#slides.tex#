\section{PVE}

%================ # 04 ========================================
\begin{frame}{Python Virtual Environment (PVE)}
  \vspace*{-3mm}
  \begin{tcolorbox}[title=Interest of a PVE, add to width=7mm]
    State of the art in Python programming:\\
    $\leadsto$ developing each project within a \bfchoco{PVE} providing an\\
    \phantom{$\leadsto$ }{\bf isolated}, {\bf dedicated}, {\bf persistent} environment:
    \medskip
    \begin{itemize}\setlength\itemsep{5mm}
    \item<2-> containing a specific installation of Python  
    \item<3-> {\bf independent} of other Python installations likely to coexist on the same machine
    \item<4-> {\bf independent} of computer updates. 
    \end{itemize}
  \end{tcolorbox}
    
\end{frame}
%==============================================================

%================ # 05 ========================================
\begin{frame}{Python Virtual Environment (PVE)}
  \vspace*{-3mm}
  \begin{tcolorbox}[title=A simple implementation..., add to width=7mm]
    A PVE is based on a {\bf dedicated disk tree} that houses:
    \medskip
    \begin{itemize}\setlength\itemsep{4mm}
    \item<2-> the desired version of the Python interpreter 
    \item<3-> the specific versions of the Python modules for the project
    \item<4-> the specific associated tools (binaries, scripts...).
    \end{itemize}
  \end{tcolorbox}

  \visible<5->{
    \begin{tcolorbox}[title=Easy to use..., add to width=7mm]
      You can {\bf create}, {\bf duplicate}, {\bf delete} and {\bf recreate} a PVE easily, without impacting other Python installations possibly present on your computer.
    \end{tcolorbox}
  }
  
\end{frame}
%==============================================================

