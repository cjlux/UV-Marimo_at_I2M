%================ # 11 ========================================
\begin{frame}[fragile]{UV $\leadsto$ the new Python project/PVE manager}
\vspace*{-3mm}
  \begin{tcolorbox}[title=Command: \boldtt{uv add}, add to width=5mm]
    \begin{itemize}\setlength\itemsep{1mm}
    \item To add a Python module to the PVE
    \item Let \textbf{uv} choose the last version of the module compatible with the interpreter version:
      \begin{minted}[fontsize=\fontsize{9}{9}\selectfont, bgcolor=VeryLightYellow]{bash}
uv add module_name
      \end{minted}
    \item Choose manually a version of the module:
      \begin{minted}[fontsize=\fontsize{9}{9}\selectfont, bgcolor=VeryLightYellow]{bash}
uv add module_name==version_number    # excatly this version
uv add module_name>=version_number    # at lest this version
uv add module_name>=n1,<n2            # between n1 and n2
      \end{minted}
    \end{itemize}
  \end{tcolorbox}

  \visible<2->
      {\small 
        \begin{itemize}\setlength\itemsep{0mm}
        \item<2-> {\bf Very fast} (parallel) download of the module and its dependencies
        \item<2-> {\bf Very efficient cache mechanism}
        \item<3-> Installs the module in the \file{.venv} directory
        \item<4-> Updates the file \file{pyproject.toml}
        \item<4-> Creates/updates \file{uv.locks} (exact version of the installed modules).
        \end{itemize}
      }
\end{frame}
%==============================================================

%================ # 12 ========================================
\begin{frame}[fragile]{UV $\leadsto$ the new Python project/PVE manager}

  \begin{tcolorbox}[title=Command: \boldtt{uv remove}, add to width=5mm]
    \begin{itemize}
    \item To remove a Python module to the PVE:
      \begin{minted}[fontsize=\fontsize{11}{11}\selectfont, bgcolor=VeryLightYellow]{bash}
uv remove module_name
      \end{minted}
    \end{itemize}
  \end{tcolorbox}

  \visible<2>{
    \small 
    \begin{itemize}\setlength\itemsep{0mm}               
    \item Removes the module from the \file{.venv} directory
    \item Updates the files \file{pyproject.toml} and \file{uv.locks}.
    \end{itemize}
  }
  
\end{frame}
%==============================================================


