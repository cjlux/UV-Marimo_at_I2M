\begin{frame}[fragile]{UV $\leadsto$ the new Python project/PVE manager}

  \begin{minipage}[t][][t]{1.\textwidth}
    \begin{tcolorbox}[title=Command: \boldtt{uv init  [dir] --python}\hfill $\leadsto$ \boldtt{uv init [dir] -p}, add to width=5mm]
      \begin{itemize}\setlength\itemsep{1mm}
